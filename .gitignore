# Dependencies generated by vcpkg manifest mode.
vcpkg_installed/

# Local environment variables.
.env

# Build output directories.
build/
out/
bin/
obj/
Debug/
Release/
x64/
x86/

# Visual Studio user/cache files.
.vs/
*.VC.db
*.VC.VC.opendb
*.suo
*.user
*.rsuser
*.sdf
*.opensdf
*.ipch
ipch/

# Visual Studio build outputs inside the vc14 project folder.
vc14/.vs/
vc14/Debug/
vc14/Release/
vc14/x64/
vc14/x86/
vc14/ipch/
vc14/theforgo.*/
vc14/*.VC.db
vc14/*.VC.VC.opendb
vc14/*.suo
vc14/*.user

# C/C++ compiler and linker outputs.
*.obj
*.pch
*.pdb
*.idb
*.ilk
*.iobj
*.ipdb
*.tlog
*.lastbuildstate
*.exp
*.lib

# Local executables and runtime DLLs copied next to the server.
*.exe
*.dll

# Logs and temporary files.
*.log
*.tmp
*.temp
*.bak
